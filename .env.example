# Full base URL of the AS Travel platform API (including /api/v1) this SPA talks
# to (bearer-token auth). NOTE: Vite inlines VITE_* vars at BUILD time, so set
# this before building for each environment.
VITE_API_URL=https://csrm.test/api/v1

# Auto-logout after this many seconds of user inactivity (defaults to 180 = 3
# minutes if unset). Inlined at build time like all VITE_* vars.
VITE_IDLE_TIMEOUT=180
# Show the "still there?" countdown modal for the final N seconds before the
# auto-logout (defaults to 30; clamped to VITE_IDLE_TIMEOUT).
VITE_IDLE_WARNING=30

# Laravel Reverb (real-time WebSockets via Laravel Echo). These mirror the
# server's REVERB_APP_* / REVERB_HOST settings. Private/presence channels are
# authorized against the API using the bearer token; override the auth URL with
# VITE_REVERB_AUTH_ENDPOINT if it isn't <API origin>/broadcasting/auth.
VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=csrm.test
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=https
# VITE_REVERB_AUTH_ENDPOINT=https://csrm.test/broadcasting/auth
